@model WebShopModel
@section Styles{
	<link href="~/css/Login.css" rel="stylesheet" />
}
<div class="wrapper fadeInDown zero-raduis">
	<div id="formContent">
		<!-- Tabs Titles -->
		<!-- Icon -->
		<div class="fadeIn first">
			<!-- <img src="http://danielzawadzki.com/codepen/01/icon.svg" id="icon" alt="User Icon" /> -->
			<h2 class="my-5">Sign In</h2>
		</div>

		<!-- Login Form -->
		@using (Html.BeginForm("Login", "WebShop", FormMethod.Post))
		{
			
			@Html.TextBoxFor(m => m.LoginModel.UserName, null, new { @class = "fadeIn third zero-raduis" })
			@Html.ValidationMessageFor(m => m.LoginModel.UserName, null, new { @class = "text text-danger" })
			
			
			@Html.PasswordFor(m => m.LoginModel.Password,  new { @class = "fadeIn third zero-raduis" })
			@Html.ValidationMessageFor(m => m.LoginModel.Password, null, new { @class = "text text-danger" })
			
			<div id="formFooter">
				<a class="underlineHover" href="#">Forgot Password?</a>
			</div>
			<input type="submit" class="fadeIn fourth zero-raduis" value="login">
			<h2>You don't have a account ?</h2>
			<input type="button" class="fadeIn fourth zero-raduis pc" value="register">
		}

	</div>
</div>